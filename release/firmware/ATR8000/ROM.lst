  63:23371+10	F6A2  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:23381+17	F6A5  CDD9F6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:23398+7+5	F6A8  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
