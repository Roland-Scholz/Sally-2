   7:				;
   8:				;	EQUATES FOR DISK CONTROLLER PORTS AND COMMAND CODES
   9:				;
  10:     -	0040          	STSREG		EQU	WD179X+0	;STATUS REGISTER
  11:     -	0040          	CMDREG		EQU	WD179X+0	;COMMAND REGISTER
  12:     -	0041          	TRKREG		EQU	WD179X+1	;TRACK REGISTER
