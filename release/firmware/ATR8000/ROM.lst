 899:				;	... DATA STRUCTURE FOR DRIVE PARAMETER BLOCKS ...
 900:				;
 901:     -	0000          	NTRKS	EQU	0		;NUMBER OF TRACKS
 902:     -	0001          	STEPRT	EQU	1		;STEP RATE
 903:     -	0002          	NSECS	EQU	2		;SECTORS PER TRACK (HI/LOW)
 904:     -	0004          	NSIDES	EQU	4		;NUMBER OF SIDES
 905:     -	0005          	MEDIA	EQU	5		;MEDIA SIZE AND FORMAT BITS
 906:     -	0006          	SECLEN	EQU	6		;SECTOR LENGTH (HI/LOW)
 907:     -	0008          	DSKBITS	EQU	8		;MISC NAUGHTY BITS
 908:     -	0009          	SPARE0	EQU	9
 909:     -	000A          	SPARE1	EQU	10
 910:     -	000B          	SPARE2	EQU	11
 911:				
 912:     -	000C          	CMDSTS	EQU	12		;COMMAND STATUS
 913:     -	000D          	HDWSTS	EQU	13		;HARDWARE STATUS
 914:				
 915:     -	000E          	FLAGS	EQU	14		;FLAGS BYTE FOR DISK OPERATION
 916:     -	000F          	SPARE3	EQU	15
 917:				;
 918:				;
 919:				;	EQUATES FOR BITS IN 'MEDIA' BYTE
 920:				;
 921:     -	0001          	SIZE	EQU	1		;DISK SIZE (1=EIGHT, 0=FIVE)
 922:     -	0002          	DENSTY	EQU	2		;DENSITY (1=DOUBLE, 0=SINGLE)
 923:				;
 924:				;
 925:				;	EQUATES FOR BITS IN 'DSKBITS' BYTE
 926:				;
 927:     -	0006          	PRESENT	EQU	6		;DRIVE PRESENT (1=PRESENT)
 928:				;
 929:				;
 930:				;	EQUATES FOR BITS IN 'CMDSTS' BYTE
 931:				;
 932:     -	0000          	BADCMD	EQU	0		;BAD COMMAND FRAME BIT
