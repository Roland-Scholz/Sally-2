  95:				
  96:23541+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:23551+4	F6CB  B7      		OR	A
  98:23555+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23570+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23574+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23584+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
