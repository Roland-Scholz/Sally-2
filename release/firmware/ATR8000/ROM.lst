  39:32740+13	FCE5  3ABCFF  		LD	A,(TRKSIZ+1)
  40:32753+4	FCE8  3C      		INC	A
  41:32757+4	FCE9  47      		LD	B,A		;LOAD B WITH # OF PAGES/TRACK PLUS ONE
  42:32761+10	FCEA  3676    	FORM2:	LD	(HL),076H	;STORE 'HALT' OPCODE
  43:32771+6	FCEC  23      		INC	HL
