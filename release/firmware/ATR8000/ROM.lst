  59:25208+4	F69A  D9      		EXX
  60:25212+7	F69B  3EFF    		LD	A,255
  61:25219+13	F69D  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
