  42:22859+11	F503  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:22870+7	F505  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F506          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:22877+11	F507  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:22888+7	F509  3E17    		LD	A,LOW RXDATA
