**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66C          	SENDBUFF:
  20:14146+11	F66C  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:14157+11	F66D  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:14168+10	F66E  2101C3  		LD	HL,IOBUFF+LEN+1
  23:14178+7	F671  73      		LD	(HL),E
  24:14185+7	F672  1600    		LD	D,0
  25:14192+17	F674  CD84F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:14209+10	F677  D1      		POP	DE
  27:14219+10	F678  E1      		POP	HL
  28:14229+7	F679  1E00    		LD	E,0
  29:14236+17	F67B  CD84F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:14253+10	F67E  2101C3  		LD	HL,IOBUFF+LEN+1
  31:14263+7	F681  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:14270+7	F682  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F684          	XMITBUF:
  38:14277+4	F684  F3      		DI
  39:14281+10	F685  0119F7  		LD	BC,STARBIT
  40:     -	F688          	SalyXMITBUF:
  41:14291+20	F688  ED4312FF		LD	(CTCVEC+2),BC	;SET UP INITIAL INTERRUPT VECTOR
  42:14311+7	F68C  0608    		LD	B,8
  43:14318+7	F68E  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  44:14325+11	F690  D381    		OUT	(CTC1),A		;PROGRAM CTC1 TO INTERRUPT AT BIT RATE
  45:14336+7	F692  3E0D    		LD	A,13			;SET TIME CONSTANT TO 13 - 52us. EXACT IS 52.083us
  46:14343+11	F694  D381    		OUT	(CTC1),A		;COUNT 13*(16*250 NS) GIVES 19200 BAUD WITH 0.16% ERROR
  47:14354+4	F696  FB      		EI
  48:14358+12	F697  18FE    		JR	$		;SPIN HERE TILL INTERRUPTS GET US OUT
  49:				;
  50:				;
  51:				;
  52:				;
  53:				;
  54:				;
  55:				;	... INTERRUPT FOR COMMAND INPUT HIGH->LOW TRANSITION ..
  56:				;
  57:     -	F699          	CSTART:
  58:14370+4	F699  08      		EX	AF,AF'
  59:14374+4	F69A  D9      		EXX
  60:14378+7	F69B  3EFF    		LD	A,255
  61:14385+13	F69D  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
  62:14398+11	F6A0  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:14409+10	F6A2  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:14419+17	F6A5  CDD9F6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:14436+7+5	F6A8  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:14443+6	F6AA  2B      		DEC	HL
  68:14449+7	F6AB  7E      		LD	A,(HL)
