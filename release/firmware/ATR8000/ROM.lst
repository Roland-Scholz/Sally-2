  86:23630+10	F6BA  2100C1  		LD	HL,IOBUFF
  87:23640+17	F6BD  CDD9F6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:23657+4	F6C0  FB      		EI
  89:23661+7+5	F6C1  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
