  59:14357+4	F69A  D9      		EXX
  60:14361+7	F69B  3EFF    		LD	A,255
  61:14368+13	F69D  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
