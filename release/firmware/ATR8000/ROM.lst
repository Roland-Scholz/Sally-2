 158:24001+11	F706  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:24012+4	F708  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:24016+11	F709  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:24027+10	F70B  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
