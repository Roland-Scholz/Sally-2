 149:23961+7	F6FD  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:23968+6	F6FE  23      		INC	HL
 151:23974+4	F6FF  7C      		LD	A,H
 152:23978+7	F700  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:23985+4	F702  3F      		CCF
