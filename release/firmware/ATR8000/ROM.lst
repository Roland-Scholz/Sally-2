 150:23988+6	F6FE  23      		INC	HL
 151:23994+4	F6FF  7C      		LD	A,H
 152:23998+7	F700  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:24005+4	F702  3F      		CCF
 154:24009+5+6	F703  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
