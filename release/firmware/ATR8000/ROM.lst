  47:				;
  48:				;	CODE PAST THIS POINT IS ONLY USED IN ATARI DISK MODE
  49:				;
  50:						INCLUDE	BITBANG.MAC
**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66C          	SENDBUFF:
  20:23474+11	F66C  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:23485+11	F66D  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:23496+10	F66E  2101C3  		LD	HL,IOBUFF+LEN+1
  23:23506+7	F671  73      		LD	(HL),E
  24:23513+7	F672  1600    		LD	D,0
  25:23520+17	F674  CD84F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:23537+10	F677  D1      		POP	DE
  27:23547+10	F678  E1      		POP	HL
  28:23557+7	F679  1E00    		LD	E,0
  29:23564+17	F67B  CD84F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:23581+10	F67E  2101C3  		LD	HL,IOBUFF+LEN+1
  31:23591+7	F681  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:23598+7	F682  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F684          	XMITBUF:
  38:23605+4	F684  F3      		DI
  39:23609+10	F685  0119F7  		LD	BC,STARBIT
  40:     -	F688          	SalyXMITBUF:
  41:23619+20	F688  ED4312FF		LD	(CTCVEC+2),BC	;SET UP INITIAL INTERRUPT VECTOR
  42:23639+7	F68C  0608    		LD	B,8
  43:23646+7	F68E  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  44:23653+11	F690  D381    		OUT	(CTC1),A		;PROGRAM CTC1 TO INTERRUPT AT BIT RATE
  45:23664+7	F692  3E0D    		LD	A,13			;SET TIME CONSTANT TO 13 - 52us. EXACT IS 52.083us
  46:23671+11	F694  D381    		OUT	(CTC1),A		;COUNT 13*(16*250 NS) GIVES 19200 BAUD WITH 0.16% ERROR
  47:23682+4	F696  FB      		EI
  48:23686+12	F697  18FE    		JR	$		;SPIN HERE TILL INTERRUPTS GET US OUT
  49:				;
  50:				;
  51:				;
  52:				;
  53:				;
  54:				;
  55:				;	... INTERRUPT FOR COMMAND INPUT HIGH->LOW TRANSITION ..
  56:				;
  57:     -	F699          	CSTART:
  58:23698+4	F699  08      		EX	AF,AF'
  59:23702+4	F69A  D9      		EXX
  60:23706+7	F69B  3EFF    		LD	A,255
  61:23713+13	F69D  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
  62:23726+11	F6A0  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:23737+10	F6A2  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:23747+17	F6A5  CDD9F6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:23764+7+5	F6A8  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:23771+6	F6AA  2B      		DEC	HL
  68:23777+7	F6AB  7E      		LD	A,(HL)
  69:23784+4	F6AC  B9      		CP	C		;COMPARE DERRIVED AND RECVD CHECKSUMS
  70:23788+7+5	F6AD  2005    		JR	NZ,CSTRT1	;JUMP IF CHECKSUM ERROR
  71:				
  72:23795+7	F6AF  3E01    		LD	A,1
  73:23802+13	F6B1  3255FF  		LD	(CMDFLG),A	;SET FLAG IF GOOD COMMAND FRAME
  74:23815+4	F6B4  08      	CSTRT1:	EX	AF,AF'
  75:23819+4	F6B5  D9      		EXX
  76:23823+4	F6B6  FB      		EI
  77:				
  78:23827+14	F6B7  ED4D    		RETI
