  72:     -	0001          	DRVSEL1		EQU	00000001B	; 1 = select drive 1
  73:     -	0002          	DRVSEL2		EQU	00000010B	; 1 = select drive 2
  74:     -	0004          	DRVSEL3		EQU	00000100B	; 1 = select drive 3
  75:     -	0008          	DRVSEL4		EQU	00001000B	; 1 = select drive 4
