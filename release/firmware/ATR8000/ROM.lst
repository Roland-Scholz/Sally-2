  92:25073+7	F6C4  7E      		LD	A,(HL)
  93:25080+4	F6C5  B9      		CP	C
  94:25084+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:25091+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:25101+4	F6CB  B7      		OR	A
  98:25105+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:25120+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:25124+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:25134+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
 103:25141+17	F6D2  CD68FC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:25158+7	F6D5  3EFF    		LD	A,255
 105:25165+4	F6D7  B7      		OR	A
 106:25169+10	F6D8  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6D9          	RXBLOCK:
 121:25179+10	F6D9  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DC          	SalyRXBLOCK:
 123:25189+10	F6DC  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:25199+12	F6DF  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
