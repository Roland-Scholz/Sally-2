**** ..\src\SERIAL.MAC ****
   1:				;
   2:				;
   3:				;
   4:				;	... BAUDRATE AND TIMING CONSIDERATIONS ...
   5:				;
   6:				;	THE FOLLOWING TABLE DETAILS THE BIT TIMES FOR THE BAUDRATES
   7:				;    SUPPORTED BY THE ATR-8000 AND THE CTC PROGRAMMING PARAMETERS
   8:				;    REQUIRED TO GENERATE THEM USING THE CTC IN THE TIMER MODE.
   9:				;    (IE. BY DIVIDING DOWN THE 4MHZ CLOCK WITH 16 OR 256 PRESCALE.)
  10:				;
  11:				;	BAUD      PERIOD    MODULUS   PRESCALE
  12:				;	----      ------    -------   --------
  13:				;      19200        52 us      13        16
  14:				;	9600       104 us      26        16
  15:				;	4800       208 us      52        16
  16:				;	2400       416 us     104        16
  17:				;	1200       832 us     208        16
  18:				;	 600      1664 us      26       256
  19:				;	 300      3328 us      52       256
  20:				;	 150      6656 us     104       256
  21:				;	  75     13312 us     208       256
  22:				;
  23:				;
  24:				;
  25:				;
  26:				;	... INTERRUPT SERVICE ROUTINES FOR SERIAL CONSOLE INPUT ...
  27:				;
  28:				;	AVERAGE EXECUTION TIME = 24.55 us FOR INTERRUPT SERVICE
  29:				;				  4.75 us FOR INTERRUPT ACKNOWLEDGE
  30:				;				 ------
  31:				;				 29.30 us PER BIT
  32:				;
  33:				;
  34:				;	*** START BAGE BOUNDARY RESTRICTIONS ***
  35:				;
  36:     -	F500          	CONPAGE	EQU	$
  37:				;
  38:				;
  39:     -	F500          	RXSTART:
  40:21877+11	F500  F5      		PUSH	AF
  41:21888+7	F501  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  42:21895+11	F503  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:21906+7	F505  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F506          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:21913+11	F507  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:21924+7	F509  3E17    		LD	A,LOW RXDATA
  47:21931+13	F50B  3210FF  		LD	(CTCVEC),A
  48:21944+7	F50E  3E7F    		LD	A,01111111B		;7 DATA BITS
  49:21951+13	F510  321CF5  	RXDAT2:	LD	(RXTEMP),A	;SET DATA SHIFTER TO ALL ONES
  50:21964+10	F513  F1      		POP	AF
  51:21974+4	F514  FB      		EI
  52:21978+14	F515  ED4D    		RETI				;EXECUTION TIME = 115 CLOCK CYCLES
  53:				;
  54:				;
  55:				;
  56:     -	F517          	RXDATA:
  57:21992+11	F517  F5      		PUSH	AF
  58:22003+11	F518  DB70    		IN	A,(ATARI)		;READ SERIAL INPUT BIT STREAM
  59:22014+4	F51A  17      		RLA					;SHIFT DATA BIT (=MSB) INTO CARRY
  60:22018+7	F51B  3E00    		LD	A,NULL			;LOAD A WITH PARTIAL DATA BYTE - NOTE THAT THIS VALUE RESETS AT LABEL RXDAT2
  61:     -	F51C          	RXTEMP	EQU	$-1
  62:22025+4	F51D  1F      		RRA					;SHIFT NEW BIT IN AND ONES OUT
  63:22029+7+5	F51E  38F0    		JR	C,RXDAT2
  64:				
  65:22036+13	F520  3200FF  		LD	(KEYBUF),A		;STORE CHARACTER IN CIRCULAR BUFFER
  66:     -	F521          	RXINP	EQU	$-2
  67:22049+7	F523  3E2C    		LD	A,LOW RXSTOP
  68:22056+13	F525  3210FF  		LD	(CTCVEC),A		;ADVANCE TO STOP BIT STATE
  69:22069+10	F528  F1      		POP	AF
  70:22079+4	F529  FB      		EI
  71:22083+14	F52A  ED4D    		RETI				;EXECUTION TIME = 105 CYCLES
  72:				;
  73:				;
  74:				;
  75:     -	F52C          	RXSTOP:
  76:22097+11	F52C  F5      		PUSH	AF
  77:22108+7	F52D  3EC7    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  78:22115+11	F52F  D380    		OUT	(CTC0),A		;ENABLE INTERRUPT FROM START BIT
  79:22126+7	F531  3E01    		LD	A,1				;SET TIME CONSTANT TO 1 - 6.5us
  80:22133+11	F533  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  81:22144+13	F535  3A21F5  		LD	A,(RXINP)
  82:22157+4	F538  3C      		INC	A
  83:22161+7	F539  E60F    		AND	00001111B		;BUMP BUFFER POINTER MODULO 16
  84:22168+13	F53B  3221F5  		LD	(RXINP),A
  85:22181+7	F53E  3E00    		LD	A,LOW RXSTART
  86:22188+13	F540  3210FF  		LD	(CTCVEC),A		;SET VECTOR BACK TO START BIT CODE
