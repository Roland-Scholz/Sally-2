  85:14513+4	F6B9  F3      		DI
  86:14517+10	F6BA  2100C1  		LD	HL,IOBUFF
  87:14527+17	F6BD  CDD9F6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:14544+4	F6C0  FB      		EI
  89:14548+7+5	F6C1  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:14555+6	F6C3  2B      		DEC	HL
  92:14561+7	F6C4  7E      		LD	A,(HL)
  93:14568+4	F6C5  B9      		CP	C
  94:14572+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:14579+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:14589+4	F6CB  B7      		OR	A
  98:14593+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:14608+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:14612+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:14622+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
 103:14629+17	F6D2  CD68FC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:14646+7	F6D5  3EFF    		LD	A,255
 105:14653+4	F6D7  B7      		OR	A
 106:14657+10	F6D8  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6D9          	RXBLOCK:
 121:14667+10	F6D9  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DC          	SalyRXBLOCK:
 123:14677+10	F6DC  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:14687+12	F6DF  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:14699+4	F6E1  79      	RXB1:	LD	A,C		;4
 127:14703+4	F6E2  80      		ADD	A,B		;4
 128:14707+7	F6E3  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:14714+4	F6E5  4F      		LD	C,A		;4
 130:14718+19	F6E6  E3      		EX	(SP),HL		;19
 131:14737+19	F6E7  E3      		EX	(SP),HL		;19
 132:14756+19	F6E8  E3      		EX	(SP),HL		;19
 133:14775+19	F6E9  E3      		EX	(SP),HL		;19
 134:14794+7	F6EA  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:14801+7	F6EC  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:14808+7	F6EE  3E0B    		LD	A,11		;  7 CYCLES
 140:14815+4	F6F0  00      		NOP			;  4 CYCLES
 141:14819+4	F6F1  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:14823+10	F6F2  C2F1F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:14833+11	F6F5  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:14844+4	F6F7  17      		RLA			;  4 CYCLES
 145:14848+8	F6F8  CB1A    		RR	D		;  8 CYCLES
