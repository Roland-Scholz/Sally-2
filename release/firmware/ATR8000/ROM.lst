  93:23634+4	F6C5  B9      		CP	C
  94:23638+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:23645+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:23655+4	F6CB  B7      		OR	A
  98:23659+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23674+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23678+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23688+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
 103:23695+17	F6D2  CD68FC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:23712+7	F6D5  3EFF    		LD	A,255
 105:23719+4	F6D7  B7      		OR	A
 106:23723+10	F6D8  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6D9          	RXBLOCK:
 121:23733+10	F6D9  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DC          	SalyRXBLOCK:
 123:23743+10	F6DC  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:23753+12	F6DF  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:23765+4	F6E1  79      	RXB1:	LD	A,C		;4
 127:23769+4	F6E2  80      		ADD	A,B		;4
 128:23773+7	F6E3  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:23780+4	F6E5  4F      		LD	C,A		;4
 130:23784+19	F6E6  E3      		EX	(SP),HL		;19
 131:23803+19	F6E7  E3      		EX	(SP),HL		;19
 132:23822+19	F6E8  E3      		EX	(SP),HL		;19
 133:23841+19	F6E9  E3      		EX	(SP),HL		;19
 134:23860+7	F6EA  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:23867+7	F6EC  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:23874+7	F6EE  3E0B    		LD	A,11		;  7 CYCLES
 140:23881+4	F6F0  00      		NOP			;  4 CYCLES
 141:23885+4	F6F1  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:23889+10	F6F2  C2F1F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:23899+11	F6F5  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:23910+4	F6F7  17      		RLA			;  4 CYCLES
 145:23914+8	F6F8  CB1A    		RR	D		;  8 CYCLES
 146:23922+8+5	F6FA  10F0    		DJNZ	RXB2		; 13 CYCLES  (8 ON FINAL BIT)
 147:				
 148:23930+4	F6FC  42      		LD	B, D		;SAVE COPY OF LAST DATA BYTE IN B
 149:23934+7	F6FD  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:23941+6	F6FE  23      		INC	HL
 151:23947+4	F6FF  7C      		LD	A,H
 152:23951+7	F700  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:23958+4	F702  3F      		CCF
 154:23962+5+6	F703  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
