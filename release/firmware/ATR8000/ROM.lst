 150:14875+6	F6FE  23      		INC	HL
 151:14881+4	F6FF  7C      		LD	A,H
 152:14885+7	F700  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:14892+4	F702  3F      		CCF
