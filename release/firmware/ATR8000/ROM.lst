  86:24065+10	F6BA  2100C1  		LD	HL,IOBUFF
  87:24075+17	F6BD  CDD9F6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:24092+4	F6C0  FB      		EI
  89:24096+7+5	F6C1  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:24103+6	F6C3  2B      		DEC	HL
  92:24109+7	F6C4  7E      		LD	A,(HL)
  93:24116+4	F6C5  B9      		CP	C
  94:24120+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:24127+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:24137+4	F6CB  B7      		OR	A
  98:24141+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:24156+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:24160+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:24170+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
