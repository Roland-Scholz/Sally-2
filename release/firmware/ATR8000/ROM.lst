  97:14572+4	F6CB  B7      		OR	A
  98:14576+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:14591+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:14595+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:14605+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
