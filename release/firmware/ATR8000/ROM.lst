 104:23739+7	F6D5  3EFF    		LD	A,255
 105:23746+4	F6D7  B7      		OR	A
 106:23750+10	F6D8  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6D9          	RXBLOCK:
 121:23760+10	F6D9  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DC          	SalyRXBLOCK:
 123:23770+10	F6DC  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:23780+12	F6DF  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:23792+4	F6E1  79      	RXB1:	LD	A,C		;4
 127:23796+4	F6E2  80      		ADD	A,B		;4
 128:23800+7	F6E3  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:23807+4	F6E5  4F      		LD	C,A		;4
 130:23811+19	F6E6  E3      		EX	(SP),HL		;19
 131:23830+19	F6E7  E3      		EX	(SP),HL		;19
 132:23849+19	F6E8  E3      		EX	(SP),HL		;19
 133:23868+19	F6E9  E3      		EX	(SP),HL		;19
 134:23887+7	F6EA  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:23894+7	F6EC  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:23901+7	F6EE  3E0B    		LD	A,11		;  7 CYCLES
 140:23908+4	F6F0  00      		NOP			;  4 CYCLES
 141:23912+4	F6F1  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:23916+10	F6F2  C2F1F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:23926+11	F6F5  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:23937+4	F6F7  17      		RLA			;  4 CYCLES
 145:23941+8	F6F8  CB1A    		RR	D		;  8 CYCLES
