  93:23661+4	F6C5  B9      		CP	C
  94:23665+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:23672+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:23682+4	F6CB  B7      		OR	A
  98:23686+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23701+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23705+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23715+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
