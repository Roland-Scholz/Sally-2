  30:32667+4	FCD3  3C      		INC	A
  31:32671+11	FCD4  D354    		OUT	(INDXCLR),A
  32:32682+7	FCD6  3E0B    		LD	A,RSTCMD+HLOAD+STEPRATE
  33:32689+17	FCD8  CD6BF3  		CALL	TYP1CMD		;ISSUE SLOW RESTORE COMMAND
  34:32706+7	FCDB  EE04    		XOR	00000100B	;FLIP TK0 STATUS BIT
  35:32713+7	FCDD  E684    		AND	10000100B
