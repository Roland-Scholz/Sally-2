  82:				;	... DATA FRAME RECEIVE SUBROUTINE ...
  83:				;
  84:     -	F6B9          	RECVBUFF:
  85:23841+4	F6B9  F3      		DI
  86:23845+10	F6BA  2100C1  		LD	HL,IOBUFF
  87:23855+17	F6BD  CDD9F6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:23872+4	F6C0  FB      		EI
  89:23876+7+5	F6C1  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:23883+6	F6C3  2B      		DEC	HL
  92:23889+7	F6C4  7E      		LD	A,(HL)
  93:23896+4	F6C5  B9      		CP	C
  94:23900+7+5	F6C6  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:23907+10	F6C8  1100C1  		LD	DE,IOBUFF
  97:23917+4	F6CB  B7      		OR	A
  98:23921+15	F6CC  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23936+4	F6CE  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23940+10	F6CF  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23950+7	F6D0  3E4E    	RBUFF2:	LD	A,'N'
 103:23957+17	F6D2  CD68FC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:23974+7	F6D5  3EFF    		LD	A,255
 105:23981+4	F6D7  B7      		OR	A
 106:23985+10	F6D8  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6D9          	RXBLOCK:
 121:23995+10	F6D9  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DC          	SalyRXBLOCK:
 123:24005+10	F6DC  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:24015+12	F6DF  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:24027+4	F6E1  79      	RXB1:	LD	A,C		;4
 127:24031+4	F6E2  80      		ADD	A,B		;4
 128:24035+7	F6E3  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:24042+4	F6E5  4F      		LD	C,A		;4
 130:24046+19	F6E6  E3      		EX	(SP),HL		;19
 131:24065+19	F6E7  E3      		EX	(SP),HL		;19
 132:24084+19	F6E8  E3      		EX	(SP),HL		;19
 133:24103+19	F6E9  E3      		EX	(SP),HL		;19
 134:24122+7	F6EA  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:24129+7	F6EC  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:24136+7	F6EE  3E0B    		LD	A,11		;  7 CYCLES
 140:24143+4	F6F0  00      		NOP			;  4 CYCLES
 141:24147+4	F6F1  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:24151+10	F6F2  C2F1F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:24161+11	F6F5  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:24172+4	F6F7  17      		RLA			;  4 CYCLES
 145:24176+8	F6F8  CB1A    		RR	D		;  8 CYCLES
 146:24184+8+5	F6FA  10F0    		DJNZ	RXB2		; 13 CYCLES  (8 ON FINAL BIT)
 147:				
 148:24192+4	F6FC  42      		LD	B, D		;SAVE COPY OF LAST DATA BYTE IN B
 149:24196+7	F6FD  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:24203+6	F6FE  23      		INC	HL
 151:24209+4	F6FF  7C      		LD	A,H
 152:24213+7	F700  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:24220+4	F702  3F      		CCF
 154:24224+5+6	F703  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
 156:     -	F704          	RXB35:
 157:24229+7	F704  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:24236+11	F706  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:24247+4	F708  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:24251+11	F709  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:24262+10	F70B  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
