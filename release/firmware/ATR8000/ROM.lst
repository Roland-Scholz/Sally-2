**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66C          	SENDBUFF:
  20:24980+11	F66C  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:24991+11	F66D  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:25002+10	F66E  2101C3  		LD	HL,IOBUFF+LEN+1
  23:25012+7	F671  73      		LD	(HL),E
  24:25019+7	F672  1600    		LD	D,0
  25:25026+17	F674  CD84F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:25043+10	F677  D1      		POP	DE
  27:25053+10	F678  E1      		POP	HL
  28:25063+7	F679  1E00    		LD	E,0
  29:25070+17	F67B  CD84F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:25087+10	F67E  2101C3  		LD	HL,IOBUFF+LEN+1
  31:25097+7	F681  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:25104+7	F682  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F684          	XMITBUF:
  38:25111+4	F684  F3      		DI
  39:25115+10	F685  0119F7  		LD	BC,STARBIT
  40:     -	F688          	SalyXMITBUF:
