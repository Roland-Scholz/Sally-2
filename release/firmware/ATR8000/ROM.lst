  40:21657+11	F500  F5      		PUSH	AF
  41:21668+7	F501  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  42:21675+11	F503  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:21686+7	F505  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F506          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:21693+11	F507  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:21704+7	F509  3E17    		LD	A,LOW RXDATA
  47:21711+13	F50B  3210FF  		LD	(CTCVEC),A
  48:21724+7	F50E  3E7F    		LD	A,01111111B		;7 DATA BITS
  49:21731+13	F510  321CF5  	RXDAT2:	LD	(RXTEMP),A	;SET DATA SHIFTER TO ALL ONES
  50:21744+10	F513  F1      		POP	AF
