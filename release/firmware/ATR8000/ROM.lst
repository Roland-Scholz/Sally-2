 131:25571+19	F6E7  E3      		EX	(SP),HL		;19
 132:25590+19	F6E8  E3      		EX	(SP),HL		;19
 133:25609+19	F6E9  E3      		EX	(SP),HL		;19
 134:25628+7	F6EA  0608    		LD	B,8		;7
