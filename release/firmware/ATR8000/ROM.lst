 157:23967+7	F704  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:23974+11	F706  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:23985+4	F708  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:23989+11	F709  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:24000+10	F70B  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
