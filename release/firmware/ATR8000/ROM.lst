 129:25226+4	F6E5  4F      		LD	C,A		;4
 130:25230+19	F6E6  E3      		EX	(SP),HL		;19
 131:25249+19	F6E7  E3      		EX	(SP),HL		;19
 132:25268+19	F6E8  E3      		EX	(SP),HL		;19
 133:25287+19	F6E9  E3      		EX	(SP),HL		;19
 134:25306+7	F6EA  0608    		LD	B,8		;7
 135:				;
