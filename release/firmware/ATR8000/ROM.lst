  62:23464+11	F6A0  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:23475+10	F6A2  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:23485+17	F6A5  CDD9F6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:23502+7+5	F6A8  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:23509+6	F6AA  2B      		DEC	HL
