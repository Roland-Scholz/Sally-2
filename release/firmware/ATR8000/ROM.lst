 129:14697+4	F6E5  4F      		LD	C,A		;4
 130:14701+19	F6E6  E3      		EX	(SP),HL		;19
 131:14720+19	F6E7  E3      		EX	(SP),HL		;19
 132:14739+19	F6E8  E3      		EX	(SP),HL		;19
 133:14758+19	F6E9  E3      		EX	(SP),HL		;19
 134:14777+7	F6EA  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:14784+7	F6EC  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:14791+7	F6EE  3E0B    		LD	A,11		;  7 CYCLES
 140:14798+4	F6F0  00      		NOP			;  4 CYCLES
