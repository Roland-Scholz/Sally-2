  77:     -	FFC6          	RWTRY:		EQU	CMDBYT+1		;READ/WRITE RETRY COUNT
  78:     -	FFC7          	TICKS:		EQU	RWTRY+1			;FREE RUNNING MILISECOND COUNTER
