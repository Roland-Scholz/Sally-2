  90:				
  91:24728+6	F6C5  2B      		DEC	HL
  92:24734+7	F6C6  7E      		LD	A,(HL)
  93:24741+4	F6C7  B9      		CP	C
  94:24745+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:24752+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:24762+4	F6CD  B7      		OR	A
