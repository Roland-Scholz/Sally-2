1999:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
2000:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
2001:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
2002:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
2003:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
2004:     -	0009          	SPARE0		EQU	9	
2005:     -	000A          	SPARE1		EQU	10	
2006:     -	000B          	SPARE2		EQU	11	
