  74:24883+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:24887+4	F6B7  D9      		EXX
  76:24891+4	F6B8  FB      		EI
  77:				
  78:24895+14	F6B9  ED4D    		RETI
