 157:24639+7	F706  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:24646+11	F708  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:24657+4	F70A  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:24661+11	F70B  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:24672+10	F70D  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
 162:				
 163:24682+11	F710  DB80    	RXB4:	IN	A,(CTC0)
 164:24693+4	F712  B7      		OR	A
 165:24697+7+5	F713  20CE    		JR	NZ,RXB1		;NEW BYTE IS COMING IF START BIT LOW
 166:24704+6	F715  1B      		DEC	DE
