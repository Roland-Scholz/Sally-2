  62:24549+11	F6A2  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:24560+10	F6A4  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:24570+17	F6A7  CDDBF6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:24587+7+5	F6AA  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:24594+6	F6AC  2B      		DEC	HL
