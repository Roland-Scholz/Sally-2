  18:     -	FF30  0000    	PERIOD:		DEFW	0			;DISK SPIN PERIOD
  19:     -	FF32  32      	HLDTIM:		DEFB	50			;HEAD LOAD DELAY
  20:     -	FF33  0A      	RWMAX:		DEFB	10			;MAX NUMBER OF READ/WRITE RETRIES
