2064:				;	... DATA STRUCTURE FOR DRIVE PARAMETER BLOCKS ...
2065:				;
2066:     -	0000          	NTRKS		EQU	0			;NUMBER OF TRACKS
2067:     -	0001          	STEPRT		EQU	1			;STEP RATE
2068:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
2069:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
2070:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
2071:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
2072:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
2073:     -	0009          	SPARE0		EQU	9	
2074:     -	000A          	SPARE1		EQU	10	
2075:     -	000B          	SPARE2		EQU	11	
2076:				
2077:     -	000C          	CMDSTS		EQU	12			;COMMAND STATUS
2078:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
2079:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
2080:     -	000F          	PERTRACK	equ 	15			;track for drive
2081:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
2082:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
2083:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
2084:     -	0014          	PERTRKS		equ	20			;if NTRKS = 1, number of tracks
2085:     -	0015          	PERSECS		equ	21			;if NTRKS = 1, number of secs
2086:     -	0016          	PERFLAGS	equ 	22			;if NTRKS = 1, number of heads	
2087:     -	0017          	PERSKEWTAB	equ	23			;NSECS+1 bytes for sector skew
2088:				;
2089:				; Bits for FLAGS
2090:				;
2091:     -	0007          	FLAGMFMFM	equ	7			;0=MFM, 1=FM
2092:     -	0006          	FLAGHDDD	equ	6			;0=HD, 1=DD
2093:     -	0005          	FLAGSIDE	equ	5
