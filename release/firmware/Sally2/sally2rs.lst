  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:25832+4	F6BB  F3      		DI
  86:25836+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:25846+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:25863+4	F6C2  FB      		EI
  89:25867+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:25874+6	F6C5  2B      		DEC	HL
  92:25880+7	F6C6  7E      		LD	A,(HL)
  93:25887+4	F6C7  B9      		CP	C
  94:25891+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:25898+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:25908+4	F6CD  B7      		OR	A
  98:25912+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:25927+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:25931+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:25941+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
 103:25948+17	F6D4  CD87FB  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:25965+7	F6D7  3EFF    		LD	A,255
 105:25972+4	F6D9  B7      		OR	A
 106:25976+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
