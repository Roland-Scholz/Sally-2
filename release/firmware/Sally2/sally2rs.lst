1943:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
1944:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
1945:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
1946:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
1947:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
1948:     -	0009          	SPARE0		EQU	9	
1949:     -	000A          	SPARE1		EQU	10	
