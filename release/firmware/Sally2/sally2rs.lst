1862:				;
1863:				;	... DATA STRUCTURE FOR DRIVE PARAMETER BLOCKS ...
1864:				;
1865:     -	0000          	NTRKS		EQU	0			;NUMBER OF TRACKS
1866:     -	0001          	STEPRT		EQU	1			;STEP RATE
1867:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
1868:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
1869:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
1870:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
1871:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
1872:     -	0009          	SPARE0		EQU	9	
1873:     -	000A          	SPARE1		EQU	10	
1874:     -	000B          	SPARE2		EQU	11	
1875:						
1876:     -	000C          	CMDSTS		EQU	12			;COMMAND STATUS
1877:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
1878:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
1879:     -	000F          	SPARE3		EQU	15	
1880:					
1881:     -	000F          	PERCONFIG	equ	15			;has percom been set?
1882:     -	0010          	PERTRACK	equ 	16			;track for drive
1883:     -	0011          	MAXSEC		equ	17			;2-bytes max sectors	
1884:     -	0013          	PERSTEPRATE	equ	19			;steprate in FDC encoding
1885:     -	0014          	PERSECLEN	equ	20			;seclen in FDC encoding (0-3)
1886:     -	0015          	PERSKEWTAB	equ	21			;NSECS+1 bytes for sector skew
1887:				;
1888:				; Bits for FLAGS
1889:				;
1890:     -	0007          	FLAGMFMFM	equ	7			;0=MFM, 1=FM
1891:     -	0006          	FLAGHDDD	equ	6			;0=HD, 1=DD
1892:     -	0005          	FLAGSIDE	equ	5
1893:				;
1894:				;
1895:				;	EQUATES FOR BITS IN 'MEDIA' BYTE
1896:				;
1897:     -	0001          	SIZE	EQU	1		;DISK SIZE (1=EIGHT, 0=FIVE)
1898:     -	0002          	DENSTY	EQU	2		;DENSITY (1=DOUBLE, 0=SINGLE)
1899:				;
1900:				;
1901:				;	EQUATES FOR BITS IN 'DSKBITS' BYTE
1902:				;
1903:     -	0006          	PRESENT	EQU	6		;DRIVE PRESENT (1=PRESENT)
1904:     -	0000          	PERCONF EQU	0		;PERCOM (1=configured)
1905:				;
1906:				;
1907:				;	EQUATES FOR BITS IN 'CMDSTS' BYTE
1908:				;
1909:     -	0000          	BADCMD	EQU	0		;BAD COMMAND FRAME BIT
1910:     -	0001          	BADDAT	EQU	1		;BAD DATA FRAME BIT
1911:     -	0002          	BADRW	EQU	2		;BAD READ/WRITE OPERATION BIT
1912:     -	0003          	WRPROT	EQU	3		;WRITE PROTECTED BIT
1913:     -	0004          	ACTIVE	EQU	4		;DRIVE READY INDICATOR BIT
1914:     -	0005          	SEC256	EQU	5		;LONG/SHORT SECTOR BIT
