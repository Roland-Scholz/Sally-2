  87:25829+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:25846+4	F6C2  FB      		EI
  89:25850+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:25857+6	F6C5  2B      		DEC	HL
  92:25863+7	F6C6  7E      		LD	A,(HL)
  93:25870+4	F6C7  B9      		CP	C
  94:25874+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:25881+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:25891+4	F6CD  B7      		OR	A
  98:25895+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:25910+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:25914+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:25924+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
 103:25931+17	F6D4  CD87FB  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:25948+7	F6D7  3EFF    		LD	A,255
 105:25955+4	F6D9  B7      		OR	A
 106:25959+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
