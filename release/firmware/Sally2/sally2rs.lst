**** ..\src\main.mac ****
  62:				;
  63:				;	CODE PAST THIS POINT IS ONLY USED IN ATARI DISK MODE
  64:				;
  65:						INCLUDE	BITBANG.MAC
**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66E          	SENDBUFF:
  20:24305+11	F66E  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:24316+11	F66F  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:24327+10	F670  2101C3  		LD	HL,IOBUFF+LEN+1
  23:24337+7	F673  73      		LD	(HL),E
  24:24344+7	F674  1600    		LD	D,0
  25:24351+17	F676  CD86F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:24368+10	F679  D1      		POP	DE
  27:24378+10	F67A  E1      		POP	HL
  28:24388+7	F67B  1E00    		LD	E,0
  29:24395+17	F67D  CD86F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:24412+10	F680  2101C3  		LD	HL,IOBUFF+LEN+1
  31:24422+7	F683  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:24429+7	F684  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F686          	XMITBUF:
  38:24436+4	F686  F3      		DI
  39:24440+10	F687  011BF7  		LD	BC,STARBIT
  40:     -	F68A          	SalyXMITBUF:
