  48:     -	FF96          	OLDPTR:		EQU 	DMATRIX+64		;POINTER TO FIRST DRIVE ACCESSED
  49:     -	FF98          	DKIOCB:		EQU 	OLDPTR+2		;DISK I/O COMMAND BLOCK
