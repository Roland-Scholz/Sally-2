2009:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
2010:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
2011:     -	000F          	PERTRACK	equ 	15			;track for drive
2012:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
2013:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
2014:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
2015:     -	0014          	PERTRKS		equ	20			;if NTRKS = 1, number of tracks
2016:     -	0015          	PERSECS		equ	21			;if NTRKS = 1, number of secs
2017:     -	0016          	PERSIDES	equ 	22			;if NTRKS = 1, number of heads	
