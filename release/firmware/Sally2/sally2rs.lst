  97:24458+4	F6CD  B7      		OR	A
  98:24462+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:24477+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:24481+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:24491+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
