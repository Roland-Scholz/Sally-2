  25:     -	0000          	SPINWAIT	EQU 00000000B		;1770/1772: Enable spin up sequence
  26:     -	0008          	NOWAITMTR	EQU 00001000B		;1770/1772: Disable spin up sequence
  27:				;
  28:				;	TYPE II COMMANDS LOW NIBBLE
