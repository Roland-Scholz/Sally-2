 901:     -	0006          	SECLEN	EQU	6		;SECTOR LENGTH (HI/LOW)
 902:     -	0008          	DSKBITS	EQU	8		;MISC NAUGHTY BITS
 903:     -	0009          	SPARE0	EQU	9
 904:     -	000A          	SPARE1	EQU	10
 905:     -	000B          	SPARE2	EQU	11
