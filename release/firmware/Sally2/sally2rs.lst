   6:						INCLUDE EQUS.MAC
**** ..\src\EQUS.MAC ****
   1:				;--------------------------------------------------
   2:				; Equates for Sally2 Hi-Speed-SIO code
   3:				;--------------------------------------------------
   4:     -	0000          	NOHIGHSPEEDSIO		EQU	0
   5:				;
   6:				;--------------------------------------------------
   7:				; Track-Buffer 26*256 bytes
   8:				;--------------------------------------------------
   9:     -	1000          	TRKBUFFER		EQU	01000h
  10:					
  11:     -	0028          	SIONORMAL		EQU	40
  12:     -	0009          	SIOFAST			EQU	9
  13:				;--------------------------------------------------
  14:				;
  15:				;--------------------------------------------------
  16:				;
  17:				;
  18:				;
  19:     -	0020          	PRINTER			EQU	20H		;PRINTER OUTPUT/INPUTS
  20:     -	0030          	LATCH			EQU	30H		;DRIVE CONTROL LATCH
  21:     -	0040          	WD179X			EQU	40H		;WD TYPE DISK CONTROLLER
  22:				;		
  23:     -	0050          	SERIN			EQU	50H		;RS232 SERIAL INPUT
  24:     -	0007          	SERRX			EQU	7		;Bit 7 : RX
  25:     -	0003          	AT850			EQU	3		;Bit 3 : ATARI 850 present
  26:     -	0002          	SERRI			EQU	2		;Bit 2 : RI (ring indicator)
  27:     -	0001          	SERCTS			EQU	1		;BIT 1 : CTS (clear to send)
  28:				;		
  29:     -	0050          	ATROUT			EQU	50H		;ATARI SERIAL OUTPUT
  30:     -	0051          	SEROUT			EQU	51H		;RS232 SERIAL OUTPUT
  31:     -	0052          	BANKSW			EQU	52H		;ROM BANKSWITCH BIT
  32:     -	0053          	STROBE			EQU	53H		;PRINTER STROBE
  33:     -	0054          	INDXCLR			EQU	54H		;INDEX CONTROL FLOP CLEAR
  34:     -	0055          	DTR			EQU	55H		;DTR OUTPUT CONTROL
  35:     -	0056          	INDXSET			EQU	56H		;INDEX CONTROL FLOP SET
  36:     -	0057          	CDMUX			EQU	57H		;ATARI CMD/DATA MUX CONTROL
  37:				;		
  38:     -	0070          	ATARI			EQU	70H		;ATARI INPUT BITS PORT
  39:     -	0080          	CTC0			EQU	80H		;ZILOG COUNTER/TIMER 0
  40:     -	0081          	CTC1			EQU	81H		;ZILOG COUNTER/TIMER 1
  41:     -	0082          	CTC2			EQU	82H		;ZILOG COUNTER/TIMER 2
  42:     -	0083          	CTC3			EQU	83H		;ZILOG COUNTER/TIMER 3
  43:				;
  44:     -	0000          	CTC_D0_VECTOR:		EQU	00000000B	;Data is a Vector
  45:     -	0001          	CTC_D0_CONTROL:		EQU	00000001B	;Data is a Control Word
  46:     -	0002          	CTC_D1_SW_RST:		EQU	00000010B	;Perform a software reset
  47:     -	0004          	CTC_D2_TCNEXT:		EQU	00000100B	;Time Constant follows
  48:     -	0000          	CTC_D3_AUTOTRG:		EQU	00000000B	;Automatic trigger when Time Constant loaded
  49:     -	0008          	CTC_D3_CLKTRG:		EQU	00001000B	;CLK/TRIG pin pulse starts timer
  50:     -	0000          	CTC_D4_FALLEDGE:	EQU	00000000B	;CLK/TRIG edge selection - falling edge
  51:     -	0010          	CTC_D4_RISEEDGE:	EQU	00010000B	;CLK/TRIG edge selection - rising edge
  52:     -	0000          	CTC_D5_PRESC_16:	EQU	00000000B	;Timer prescaler value of 16
  53:     -	0020          	CTC_D5_PRESC256:	EQU	00100000B	;Timer prescaler value of 256
  54:     -	0000          	CTC_D6_MODE_TIM:	EQU	00000000B	;Selects Timer mode
  55:     -	0040          	CTC_D6_MODE_CNT:	EQU	01000000B	;Selects Counter mode
  56:     -	0000          	CTC_D7_INT_DIS:		EQU	00000000B	;Disables Interrupt
  57:     -	0080          	CTC_D7_INT_EN:		EQU	10000000B	;Enables Interrupt
  58:				;
  59:     -	0000          	NULL			EQU	00H
  60:     -	000D          	CR			EQU	0DH
  61:     -	000A          	LF			EQU	0AH
  62:				;
