 176:32566+11	FCFD  E5      		PUSH	HL
 177:32577+14	FCFE  DDE1    		POP	IX		;IX POINTS TO START OF SECTOR POOP
 178:32591+13	FD00  3A2DFF  	BUILD3:	LD	A,(TRACK)
 179:32604+19	FD03  DD7707  		LD	(IX+7),A	;STORE TRACK# FOR TRACK BEING FORMATTED
 180:32623+13	FD06  3A2FFF  		ld	a,(outcpy)
 181:32636+7	FD09  E620    		and	00100000b
 182:32643+7	FD0B  3E00    		ld	a,0
 183:32650+7+5	FD0D  2801    		jr	z,bild31	;jump if formatting side 0
 184:32657+4	FD0F  3C      		inc	a
