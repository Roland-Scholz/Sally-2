  62:24557+11	F6A2  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:24568+10	F6A4  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:24578+17	F6A7  CDDBF6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:24595+7+5	F6AA  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:24602+6	F6AC  2B      		DEC	HL
  68:24608+7	F6AD  7E      		LD	A,(HL)
