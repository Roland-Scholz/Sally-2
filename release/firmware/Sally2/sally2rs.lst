1983:     -	000C          	CMDSTS		EQU	12			;COMMAND STATUS
1984:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
1985:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
1986:     -	000F          	PERTRACK	equ 	15			;track for drive
1987:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
1988:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
1989:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
1990:     -	0014          	PERTRKS		equ	20			;if NTRKS = 1, number of tracks
1991:     -	0015          	PERSECS		equ	21			;if NTRKS = 1, number of secs
1992:     -	0016          	PERSIDES	equ 	22			;if NTRKS = 1, number of heads	
1993:     -	0017          	PERSKEWTAB	equ	23			;NSECS+1 bytes for sector skew
