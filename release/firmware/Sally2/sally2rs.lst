**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66E          	SENDBUFF:
  20:24015+11	F66E  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:24026+11	F66F  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:24037+10	F670  2101C3  		LD	HL,IOBUFF+LEN+1
  23:24047+7	F673  73      		LD	(HL),E
  24:24054+7	F674  1600    		LD	D,0
  25:24061+17	F676  CD86F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:24078+10	F679  D1      		POP	DE
  27:24088+10	F67A  E1      		POP	HL
  28:24098+7	F67B  1E00    		LD	E,0
  29:24105+17	F67D  CD86F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:24122+10	F680  2101C3  		LD	HL,IOBUFF+LEN+1
  31:24132+7	F683  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:24139+7	F684  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F686          	XMITBUF:
  38:24146+4	F686  F3      		DI
  39:24150+10	F687  011BF7  		LD	BC,STARBIT
  40:     -	F68A          	SalyXMITBUF:
  41:24160+20	F68A  ED4312FF		LD	(CTCVEC+2),BC	;SET UP INITIAL INTERRUPT VECTOR
  42:24180+7	F68E  0608    		LD	B,8
  43:24187+7	F690  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  44:24194+11	F692  D381    		OUT	(CTC1),A		;PROGRAM CTC1 TO INTERRUPT AT BIT RATE
  45:24205+7	F694  3E0D    		LD	A,13			;SET TIME CONSTANT TO 13 - 52us. EXACT IS 52.083us
  46:24212+11	F696  D381    		OUT	(CTC1),A		;COUNT 13*(16*250 NS) GIVES 19200 BAUD WITH 0.16% ERROR
  47:24223+4	F698  FB      		EI
  48:24227+12	F699  18FE    		JR	$		;SPIN HERE TILL INTERRUPTS GET US OUT
  49:				;
  50:				;
  51:				;
  52:				;
  53:				;
  54:				;
  55:				;	... INTERRUPT FOR COMMAND INPUT HIGH->LOW TRANSITION ..
  56:				;
