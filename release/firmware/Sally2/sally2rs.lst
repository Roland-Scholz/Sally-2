  41:22078+7	F503  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  42:22085+11	F505  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:22096+7	F507  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F508          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:22103+11	F509  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:22114+7	F50B  3E19    		LD	A,LOW RXDATA
  47:22121+13	F50D  3210FF  		LD	(CTCVEC),A
  48:22134+7	F510  3E7F    		LD	A,01111111B		;7 DATA BITS
