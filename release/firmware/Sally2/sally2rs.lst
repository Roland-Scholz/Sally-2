 129:24583+4	F6E7  4F      		LD	C,A		;4
 130:24587+19	F6E8  E3      		EX	(SP),HL		;19
 131:24606+19	F6E9  E3      		EX	(SP),HL		;19
 132:24625+19	F6EA  E3      		EX	(SP),HL		;19
 133:24644+19	F6EB  E3      		EX	(SP),HL		;19
 134:24663+7	F6EC  0608    		LD	B,8		;7
