1993:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
1994:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
1995:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
1996:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
1997:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
1998:     -	0009          	SPARE0		EQU	9	
1999:     -	000A          	SPARE1		EQU	10	
2000:     -	000B          	SPARE2		EQU	11	
