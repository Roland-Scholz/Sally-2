2003:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
2004:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
2005:     -	000F          	PERTRACK	equ 	15			;track for drive
2006:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
2007:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
2008:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
2009:     -	0014          	PERTRKS		equ	20			;if NTRKS = 1, number of tracks
2010:     -	0015          	PERSECS		equ	21			;if NTRKS = 1, number of secs
2011:     -	0016          	PERSIDES	equ 	22			;if NTRKS = 1, number of heads	
