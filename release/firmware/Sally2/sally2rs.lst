  80:				;
  81:				;
  82:				;	... DATA FRAME RECEIVE SUBROUTINE ...
  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:24667+4	F6BB  F3      		DI
  86:24671+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:24681+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:24698+4	F6C2  FB      		EI
  89:24702+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:24709+6	F6C5  2B      		DEC	HL
  92:24715+7	F6C6  7E      		LD	A,(HL)
  93:24722+4	F6C7  B9      		CP	C
  94:24726+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:24733+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:24743+4	F6CD  B7      		OR	A
  98:24747+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:24762+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:24766+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
