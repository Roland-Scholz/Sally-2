1991:     -	000F          	PERTRACK	equ 	15			;track for drive
1992:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
1993:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
1994:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
