  52:     -	FFAB          	IDBUF:		EQU	LOGSIZ+2		;BUFFER FOR ID MARK READS
  53:     -	FFB3          	IOPTR:		EQU 	IDBUF+8			;ATARI BLOCK INPUT POINTER
