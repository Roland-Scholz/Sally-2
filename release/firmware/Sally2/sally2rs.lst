  28:     -	FF3C  E3F7    	EXTVEC:		DEFW	DUMMY			;POINTER FOR EXTRA TASK PROCESSOR
  29:     -	FF3E  020D0A00	NEWLIN:		DEFB	2,CR,LF,0,0		;PRINTER NEWLINE CHARACTERS
	              00
  30:     -	FF43  00003C00	PSMSG:		DEFB	0,0,60,0		;PRINTER STATUS FRAME
