1953:     -	000D          	HDWSTS		EQU	13			;HARDWARE STATUS
1954:     -	000E          	FLAGS		EQU	14			;FLAGS BYTE FOR DISK OPERATION
1955:     -	000F          	PERTRACK	equ 	15			;track for drive
1956:     -	0010          	MAXSEC		equ	16			;2-bytes max sectors	
1957:     -	0012          	PERSTEPRATE	equ	18			;steprate in FDC encoding
1958:     -	0013          	PERSECLEN	equ	19			;seclen in FDC encoding (0-3)
1959:     -	0014          	PERTRKS		equ	20			;if NTRKS = 1, number of tracks
1960:     -	0015          	PERSECS		equ	21			;if NTRKS = 1, number of secs
1961:     -	0016          	PERSIDES	equ 	22			;if NTRKS = 1, number of heads	
