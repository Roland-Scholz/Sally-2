  74:25789+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:25793+4	F6B7  D9      		EXX
  76:25797+4	F6B8  FB      		EI
  77:				
  78:25801+14	F6B9  ED4D    		RETI
