**** ..\src\SERIAL.MAC ****
   1:				;
   2:				;
   3:				;
   4:				;	... BAUDRATE AND TIMING CONSIDERATIONS ...
   5:				;
   6:				;	THE FOLLOWING TABLE DETAILS THE BIT TIMES FOR THE BAUDRATES
   7:				;    SUPPORTED BY THE ATR-8000 AND THE CTC PROGRAMMING PARAMETERS
   8:				;    REQUIRED TO GENERATE THEM USING THE CTC IN THE TIMER MODE.
   9:				;    (IE. BY DIVIDING DOWN THE 4MHZ CLOCK WITH 16 OR 256 PRESCALE.)
  10:				;
  11:				;	BAUD      PERIOD    MODULUS   PRESCALE
  12:				;	----      ------    -------   --------
  13:				;      19200        52 us      13        16
  14:				;	9600       104 us      26        16
  15:				;	4800       208 us      52        16
  16:				;	2400       416 us     104        16
  17:				;	1200       832 us     208        16
  18:				;	 600      1664 us      26       256
  19:				;	 300      3328 us      52       256
  20:				;	 150      6656 us     104       256
  21:				;	  75     13312 us     208       256
  22:				;
  23:				;
  24:				;
  25:				;
  26:				;	... INTERRUPT SERVICE ROUTINES FOR SERIAL CONSOLE INPUT ...
  27:				;
  28:				;	AVERAGE EXECUTION TIME = 24.55 us FOR INTERRUPT SERVICE
  29:				;				  4.75 us FOR INTERRUPT ACKNOWLEDGE
  30:				;				 ------
  31:				;				 29.30 us PER BIT
  32:				;
  33:				;
  34:				;	*** START BAGE BOUNDARY RESTRICTIONS ***
  35:				;
  36:     -	F502          	CONPAGE	EQU	$
  37:				;
  38:				;
  39:     -	F502          	RXSTART:
  40:22480+11	F502  F5      		PUSH	AF
  41:22491+7	F503  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  42:22498+11	F505  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:22509+7	F507  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F508          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:22516+11	F509  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:22527+7	F50B  3E19    		LD	A,LOW RXDATA
  47:22534+13	F50D  3210FF  		LD	(CTCVEC),A
  48:22547+7	F510  3E7F    		LD	A,01111111B		;7 DATA BITS
  49:22554+13	F512  321EF5  	RXDAT2:	LD	(RXTEMP),A	;SET DATA SHIFTER TO ALL ONES
  50:22567+10	F515  F1      		POP	AF
  51:22577+4	F516  FB      		EI
  52:22581+14	F517  ED4D    		RETI				;EXECUTION TIME = 115 CLOCK CYCLES
  53:				;
  54:				;
  55:				;
  56:     -	F519          	RXDATA:
  57:22595+11	F519  F5      		PUSH	AF
  58:22606+11	F51A  DB70    		IN	A,(ATARI)		;READ SERIAL INPUT BIT STREAM
  59:22617+4	F51C  17      		RLA					;SHIFT DATA BIT (=MSB) INTO CARRY
  60:22621+7	F51D  3E00    		LD	A,NULL			;LOAD A WITH PARTIAL DATA BYTE - NOTE THAT THIS VALUE RESETS AT LABEL RXDAT2
  61:     -	F51E          	RXTEMP	EQU	$-1
  62:22628+4	F51F  1F      		RRA					;SHIFT NEW BIT IN AND ONES OUT
  63:22632+7+5	F520  38F0    		JR	C,RXDAT2
  64:				
  65:22639+13	F522  3200FF  		LD	(KEYBUF),A		;STORE CHARACTER IN CIRCULAR BUFFER
  66:     -	F523          	RXINP	EQU	$-2
  67:22652+7	F525  3E2E    		LD	A,LOW RXSTOP
  68:22659+13	F527  3210FF  		LD	(CTCVEC),A		;ADVANCE TO STOP BIT STATE
  69:22672+10	F52A  F1      		POP	AF
  70:22682+4	F52B  FB      		EI
  71:22686+14	F52C  ED4D    		RETI				;EXECUTION TIME = 105 CYCLES
  72:				;
  73:				;
  74:				;
  75:     -	F52E          	RXSTOP:
  76:22700+11	F52E  F5      		PUSH	AF
  77:22711+7	F52F  3EC7    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  78:22718+11	F531  D380    		OUT	(CTC0),A		;ENABLE INTERRUPT FROM START BIT
  79:22729+7	F533  3E01    		LD	A,1				;SET TIME CONSTANT TO 1 - 6.5us
  80:22736+11	F535  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  81:22747+13	F537  3A23F5  		LD	A,(RXINP)
  82:22760+4	F53A  3C      		INC	A
  83:22764+7	F53B  E60F    		AND	00001111B		;BUMP BUFFER POINTER MODULO 16
  84:22771+13	F53D  3223F5  		LD	(RXINP),A
  85:22784+7	F540  3E02    		LD	A,LOW RXSTART
  86:22791+13	F542  3210FF  		LD	(CTCVEC),A		;SET VECTOR BACK TO START BIT CODE
