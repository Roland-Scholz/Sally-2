  93:26195+4	F6C7  B9      		CP	C
  94:26199+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:26206+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:26216+4	F6CD  B7      		OR	A
