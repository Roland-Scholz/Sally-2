 167:32485+10	FCEF  E1      		POP	HL
 168:32495+7	FCF0  46      		LD	B,(HL)		;LOAD B WITH # OF FIELDS IN PREAMBLE
 169:32502+6	FCF1  23      		INC	HL
 170:32508+20	FCF2  ED5BC3FF		LD	DE,(TRKPTR)
 171:32528+17	FCF6  CD50FD  	BUILD1:	CALL	INSERT		;INSERT FIELDS OF PREAMBLE
 172:32545+8+5	FCF9  10FB    		DJNZ	BUILD1
