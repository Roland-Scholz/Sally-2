 124:24133+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:24145+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:24149+4	F6E4  80      		ADD	A,B		;4
 128:24153+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:24160+4	F6E7  4F      		LD	C,A		;4
 130:24164+19	F6E8  E3      		EX	(SP),HL		;19
 131:24183+19	F6E9  E3      		EX	(SP),HL		;19
 132:24202+19	F6EA  E3      		EX	(SP),HL		;19
 133:24221+19	F6EB  E3      		EX	(SP),HL		;19
 134:24240+7	F6EC  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:24247+7	F6EE  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
