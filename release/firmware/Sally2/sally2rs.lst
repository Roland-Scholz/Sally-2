1971:				;
1972:     -	0000          	NTRKS		EQU	0			;NUMBER OF TRACKS
1973:     -	0001          	STEPRT		EQU	1			;STEP RATE
1974:     -	0002          	NSECS		EQU	2			;SECTORS PER TRACK (HI/LOW)
1975:     -	0004          	NSIDES		EQU	4			;NUMBER OF SIDES
1976:     -	0005          	MEDIA		EQU	5			;MEDIA SIZE AND FORMAT BITS
1977:     -	0006          	SECLEN		EQU	6			;SECTOR LENGTH (HI/LOW)
1978:     -	0008          	DSKBITS		EQU	8			;MISC NAUGHTY BITS
1979:     -	0009          	SPARE0		EQU	9	
1980:     -	000A          	SPARE1		EQU	10	
1981:     -	000B          	SPARE2		EQU	11	
