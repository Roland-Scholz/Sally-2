  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:24664+4	F6BB  F3      		DI
  86:24668+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:24678+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:24695+4	F6C2  FB      		EI
  89:24699+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:24706+6	F6C5  2B      		DEC	HL
  92:24712+7	F6C6  7E      		LD	A,(HL)
  93:24719+4	F6C7  B9      		CP	C
  94:24723+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:24730+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:24740+4	F6CD  B7      		OR	A
  98:24744+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:24759+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:24763+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:24773+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
