  74:24849+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:24853+4	F6B7  D9      		EXX
  76:24857+4	F6B8  FB      		EI
  77:				
  78:24861+14	F6B9  ED4D    		RETI
