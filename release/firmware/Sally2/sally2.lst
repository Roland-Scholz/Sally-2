  69:     -	FFBF          	SEQNUM:		EQU	tracks+1		;TEMP SECTOR SEQUENCE NUMBER
  70:     -	FFC1          	SEQPTR:		EQU	SEQNUM+2		;TEMP ERROR LOG TABLE POINTER
