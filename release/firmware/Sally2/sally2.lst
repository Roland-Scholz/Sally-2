  42:12398+11	F505  D380    		OUT	(CTC0),A		;RESET CTC AND PROGRAM FOR TIMER MODE
  43:12409+7	F507  3E1A    		LD	A,26			;TIME CONSTANT OF 26 - exactly 104us WHICH IS 9600 BAUD
  44:     -	F508          	RXBAUD	EQU	$-1			;BAUDRATE PARAM IS STORED HERE
  45:12416+11	F509  D380    		OUT	(CTC0),A		;PROGRAM THE TIME CONSTANT
  46:12427+7	F50B  3E19    		LD	A,LOW RXDATA
