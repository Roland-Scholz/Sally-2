 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
 121:23697+10	F6DB  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DE          	SalyRXBLOCK:
 123:23707+10	F6DE  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:23717+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:23729+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:23733+4	F6E4  80      		ADD	A,B		;4
 128:23737+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:23744+4	F6E7  4F      		LD	C,A		;4
 130:23748+19	F6E8  E3      		EX	(SP),HL		;19
 131:23767+19	F6E9  E3      		EX	(SP),HL		;19
 132:23786+19	F6EA  E3      		EX	(SP),HL		;19
 133:23805+19	F6EB  E3      		EX	(SP),HL		;19
 134:23824+7	F6EC  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:23831+7	F6EE  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:23838+7	F6F0  3E0B    		LD	A,11		;  7 CYCLES
 140:23845+4	F6F2  00      		NOP			;  4 CYCLES
