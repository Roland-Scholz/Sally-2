2341:     -	0BA3  5001    	INITAB:		DEFB	ATROUT,1				;SET ATART OUTPUT TO MARK STATE
2342:     -	0BA5  5101    			DEFB	SEROUT,1				;SET RS232 OUTPUT TO MARK STATE
2343:     -	0BA7  8003    			DEFB	CTC0, CTC_D1_SW_RST + CTC_D0_CONTROL	;SOFTWARE RESET CTC0
2344:     -	0BA9  8010    			DEFB	CTC0, low ctcvec			;SET CTC0 BASE INTERRUPT VECTOR
2345:     -	0BAB  8107    			DEFB	CTC1, CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	;PUT CTC1 IN TIMER MODE + SET TIME CONSTANT
2346:     -	0BAD  8101    			DEFB	CTC1, 1					;CTC1 TIME CONSTANT (DIVIDE BY 1 - 6.5us)
2347:     -	0BAF  8203    			DEFB	CTC2, CTC_D1_SW_RST + CTC_D0_CONTROL	;SOFTWARE RESET CTC2
2348:     -	0BB1  8303    			DEFB	CTC3, CTC_D1_SW_RST + CTC_D0_CONTROL	;SOFTWARE RESET CTC3
2349:     -	0BB3  5701    			DEFB	CDMUX, 1				;SET MUX TO PASS ATARI DATA
2350:     -	0001          		IF WD1772
2351:     -	0BB5  3050    			DB	LATCH, 050h				;DRIVE CONTROL reset FDC
2352:     -	0BB7  3040    			DB	LATCH, 040h				;DRIVE CONTROL 8Mhz
2353:					ELSE
2356:					ENDIF	;WD1772
2357:     -	0016          	ITBLEN		EQU	$-INITAB
