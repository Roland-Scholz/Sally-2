  82:				;	... DATA FRAME RECEIVE SUBROUTINE ...
  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:25093+4	F6BB  F3      		DI
  86:25097+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:25107+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:25124+4	F6C2  FB      		EI
  89:25128+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:25135+6	F6C5  2B      		DEC	HL
  92:25141+7	F6C6  7E      		LD	A,(HL)
  93:25148+4	F6C7  B9      		CP	C
  94:25152+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:25159+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:25169+4	F6CD  B7      		OR	A
  98:25173+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:25188+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:25192+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:25202+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
 103:25209+17	F6D4  CD6AFC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:25226+7	F6D7  3EFF    		LD	A,255
 105:25233+4	F6D9  B7      		OR	A
 106:25237+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
 121:25247+10	F6DB  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DE          	SalyRXBLOCK:
 123:25257+10	F6DE  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:25267+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:25279+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:25283+4	F6E4  80      		ADD	A,B		;4
 128:25287+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:25294+4	F6E7  4F      		LD	C,A		;4
 130:25298+19	F6E8  E3      		EX	(SP),HL		;19
 131:25317+19	F6E9  E3      		EX	(SP),HL		;19
 132:25336+19	F6EA  E3      		EX	(SP),HL		;19
 133:25355+19	F6EB  E3      		EX	(SP),HL		;19
 134:25374+7	F6EC  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:25381+7	F6EE  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:25388+7	F6F0  3E0B    		LD	A,11		;  7 CYCLES
 140:25395+4	F6F2  00      		NOP			;  4 CYCLES
 141:25399+4	F6F3  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:25403+10	F6F4  C2F3F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:25413+11	F6F7  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:25424+4	F6F9  17      		RLA			;  4 CYCLES
 145:25428+8	F6FA  CB1A    		RR	D		;  8 CYCLES
 146:25436+8+5	F6FC  10F0    		DJNZ	RXB2		; 13 CYCLES  (8 ON FINAL BIT)
 147:				
