 149:25448+7	F6FF  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:25455+6	F700  23      		INC	HL
 151:25461+4	F701  7C      		LD	A,H
 152:25465+7	F702  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:25472+4	F704  3F      		CCF
 154:25476+5+6	F705  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
 156:     -	F706          	RXB35:
 157:25481+7	F706  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:25488+11	F708  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:25499+4	F70A  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:25503+11	F70B  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:25514+10	F70D  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
 162:				
 163:25524+11	F710  DB80    	RXB4:	IN	A,(CTC0)
 164:25535+4	F712  B7      		OR	A
 165:25539+7+5	F713  20CE    		JR	NZ,RXB1		;NEW BYTE IS COMING IF START BIT LOW
 166:25546+6	F715  1B      		DEC	DE
 167:25552+4	F716  7A      		LD	A,D
 168:25556+4	F717  B3      		OR	E
 169:25560+7+5	F718  20F6    		JR	NZ,RXB4		;ELSE LOOP TILL TIMER RUNS OUT
 170:				
 171:25567+10	F71A  C9      		RET			;RETURN WITH CARRY CLEAR IF TIMED OUT
