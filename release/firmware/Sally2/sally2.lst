  92:     -	0002          	DSKTRK		EQU	2		;TRACK#
  93:     -	0003          	DSKSEC		EQU	3		;SECTOR#
  94:     -	0004          	DSKPTR		EQU	4		;READ/WRITE POINTER
  95:     -	0006          	DSKAUX		EQU	6		;AUXILLIARY PARAMETERS (2 BYTES)
