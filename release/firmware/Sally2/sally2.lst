 104:24042+7	F6D7  3EFF    		LD	A,255
 105:24049+4	F6D9  B7      		OR	A
 106:24053+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
 121:24063+10	F6DB  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DE          	SalyRXBLOCK:
 123:24073+10	F6DE  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:24083+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:24095+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:24099+4	F6E4  80      		ADD	A,B		;4
 128:24103+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:24110+4	F6E7  4F      		LD	C,A		;4
 130:24114+19	F6E8  E3      		EX	(SP),HL		;19
