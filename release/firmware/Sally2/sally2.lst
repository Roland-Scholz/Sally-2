 158:23938+11	F708  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:23949+4	F70A  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:23953+11	F70B  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:23964+10	F70D  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
