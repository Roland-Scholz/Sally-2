**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66E          	SENDBUFF:
  20:25048+11	F66E  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:25059+11	F66F  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:25070+10	F670  2101C3  		LD	HL,IOBUFF+LEN+1
  23:25080+7	F673  73      		LD	(HL),E
  24:25087+7	F674  1600    		LD	D,0
  25:25094+17	F676  CD86F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:25111+10	F679  D1      		POP	DE
  27:25121+10	F67A  E1      		POP	HL
  28:25131+7	F67B  1E00    		LD	E,0
  29:25138+17	F67D  CD86F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:25155+10	F680  2101C3  		LD	HL,IOBUFF+LEN+1
  31:25165+7	F683  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:25172+7	F684  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F686          	XMITBUF:
  38:25179+4	F686  F3      		DI
  39:25183+10	F687  011BF7  		LD	BC,STARBIT
  40:     -	F68A          	SalyXMITBUF:
  41:25193+20	F68A  ED4312FF		LD	(CTCVEC+2),BC	;SET UP INITIAL INTERRUPT VECTOR
  42:25213+7	F68E  0608    		LD	B,8
  43:25220+7	F690  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  44:25227+11	F692  D381    		OUT	(CTC1),A		;PROGRAM CTC1 TO INTERRUPT AT BIT RATE
  45:25238+7	F694  3E0D    		LD	A,13			;SET TIME CONSTANT TO 13 - 52us. EXACT IS 52.083us
  46:25245+11	F696  D381    		OUT	(CTC1),A		;COUNT 13*(16*250 NS) GIVES 19200 BAUD WITH 0.16% ERROR
  47:25256+4	F698  FB      		EI
  48:25260+12	F699  18FE    		JR	$		;SPIN HERE TILL INTERRUPTS GET US OUT
  49:				;
  50:				;
  51:				;
  52:				;
  53:				;
  54:				;
  55:				;	... INTERRUPT FOR COMMAND INPUT HIGH->LOW TRANSITION ..
  56:				;
  57:     -	F69B          	CSTART:
  58:25272+4	F69B  08      		EX	AF,AF'
  59:25276+4	F69C  D9      		EXX
  60:25280+7	F69D  3EFF    		LD	A,255
  61:25287+13	F69F  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
  62:25300+11	F6A2  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:25311+10	F6A4  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:25321+17	F6A7  CDDBF6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:25338+7+5	F6AA  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:25345+6	F6AC  2B      		DEC	HL
  68:25351+7	F6AD  7E      		LD	A,(HL)
  69:25358+4	F6AE  B9      		CP	C		;COMPARE DERRIVED AND RECVD CHECKSUMS
  70:25362+7+5	F6AF  2005    		JR	NZ,CSTRT1	;JUMP IF CHECKSUM ERROR
  71:				
  72:25369+7	F6B1  3E01    		LD	A,1
  73:25376+13	F6B3  3255FF  		LD	(CMDFLG),A	;SET FLAG IF GOOD COMMAND FRAME
  74:25389+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:25393+4	F6B7  D9      		EXX
  76:25397+4	F6B8  FB      		EI
  77:				
  78:25401+14	F6B9  ED4D    		RETI
  79:				;
  80:				;
  81:				;
  82:				;	... DATA FRAME RECEIVE SUBROUTINE ...
  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:25415+4	F6BB  F3      		DI
  86:25419+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:25429+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:25446+4	F6C2  FB      		EI
  89:25450+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:25457+6	F6C5  2B      		DEC	HL
  92:25463+7	F6C6  7E      		LD	A,(HL)
  93:25470+4	F6C7  B9      		CP	C
  94:25474+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:25481+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:25491+4	F6CD  B7      		OR	A
  98:25495+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:25510+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:25514+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:25524+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
 103:25531+17	F6D4  CD6AFC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:25548+7	F6D7  3EFF    		LD	A,255
 105:25555+4	F6D9  B7      		OR	A
 106:25559+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
 121:25569+10	F6DB  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DE          	SalyRXBLOCK:
 123:25579+10	F6DE  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:25589+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:25601+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:25605+4	F6E4  80      		ADD	A,B		;4
 128:25609+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:25616+4	F6E7  4F      		LD	C,A		;4
 130:25620+19	F6E8  E3      		EX	(SP),HL		;19
 131:25639+19	F6E9  E3      		EX	(SP),HL		;19
 132:25658+19	F6EA  E3      		EX	(SP),HL		;19
 133:25677+19	F6EB  E3      		EX	(SP),HL		;19
 134:25696+7	F6EC  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:25703+7	F6EE  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:25710+7	F6F0  3E0B    		LD	A,11		;  7 CYCLES
 140:25717+4	F6F2  00      		NOP			;  4 CYCLES
 141:25721+4	F6F3  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:25725+10	F6F4  C2F3F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:25735+11	F6F7  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:25746+4	F6F9  17      		RLA			;  4 CYCLES
 145:25750+8	F6FA  CB1A    		RR	D		;  8 CYCLES
 146:25758+8+5	F6FC  10F0    		DJNZ	RXB2		; 13 CYCLES  (8 ON FINAL BIT)
 147:				
 148:25766+4	F6FE  42      		LD	B, D		;SAVE COPY OF LAST DATA BYTE IN B
 149:25770+7	F6FF  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:25777+6	F700  23      		INC	HL
 151:25783+4	F701  7C      		LD	A,H
 152:25787+7	F702  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:25794+4	F704  3F      		CCF
 154:25798+5+6	F705  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
 156:     -	F706          	RXB35:
 157:25803+7	F706  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:25810+11	F708  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:25821+4	F70A  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:25825+11	F70B  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:25836+10	F70D  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
 162:				
 163:25846+11	F710  DB80    	RXB4:	IN	A,(CTC0)
 164:25857+4	F712  B7      		OR	A
 165:25861+7+5	F713  20CE    		JR	NZ,RXB1		;NEW BYTE IS COMING IF START BIT LOW
 166:25868+6	F715  1B      		DEC	DE
 167:25874+4	F716  7A      		LD	A,D
 168:25878+4	F717  B3      		OR	E
 169:25882+7+5	F718  20F6    		JR	NZ,RXB4		;ELSE LOOP TILL TIMER RUNS OUT
 170:				
 171:25889+10	F71A  C9      		RET			;RETURN WITH CARRY CLEAR IF TIMED OUT
