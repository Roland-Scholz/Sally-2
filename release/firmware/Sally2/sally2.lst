**** ..\src\EQUS.MAC ****
   1:				;--------------------------------------------------
   2:				; Equates for Sally2 Hi-Speed-SIO code
   3:				;--------------------------------------------------
   4:     -	0000          	NOHIGHSPEEDSIO		EQU	0
   5:				;
   6:				;--------------------------------------------------
   7:				; Track-Buffer 26*256 bytes
   8:				;--------------------------------------------------
   9:     -	1000          	TRKBUFFER		EQU	01000h
  10:					
  11:     -	0028          	SIONORMAL		EQU	40
  12:     -	0009          	SIOFAST			EQU	9
  13:				;--------------------------------------------------
  14:				;
  15:				;--------------------------------------------------
  16:				;
  17:				;
  18:				;
  19:     -	0020          	PRINTER			EQU	20H		;PRINTER OUTPUT/INPUTS
  20:     -	0030          	LATCH			EQU	30H		;DRIVE CONTROL LATCH
  21:     -	0040          	WD179X			EQU	40H		;WD TYPE DISK CONTROLLER
  22:				;		
  23:     -	0050          	SERIN			EQU	50H		;RS232 SERIAL INPUT
  24:     -	0007          	SERRX			EQU	7		;Bit 7 : RX
  25:     -	0003          	AT850			EQU	3		;Bit 3 : ATARI 850 present
  26:     -	0002          	SERRI			EQU	2		;Bit 2 : RI (ring indicator)
  27:     -	0001          	SERCTS			EQU	1		;BIT 1 : CTS (clear to send)
  28:				
  29:     -	0002          	XF551BIT		EQU	2
  30:				;		
  31:     -	0050          	ATROUT			EQU	50H		;ATARI SERIAL OUTPUT
  32:     -	0051          	SEROUT			EQU	51H		;RS232 SERIAL OUTPUT
  33:     -	0052          	BANKSW			EQU	52H		;ROM BANKSWITCH BIT
  34:     -	0053          	STROBE			EQU	53H		;PRINTER STROBE
  35:     -	0054          	INDXCLR			EQU	54H		;INDEX CONTROL FLOP CLEAR
  36:     -	0055          	DTR			EQU	55H		;DTR OUTPUT CONTROL
  37:     -	0056          	INDXSET			EQU	56H		;INDEX CONTROL FLOP SET
  38:     -	0057          	CDMUX			EQU	57H		;ATARI CMD/DATA MUX CONTROL
  39:				;		
  40:     -	0070          	ATARI			EQU	70H		;ATARI INPUT BITS PORT
  41:     -	0080          	CTC0			EQU	80H		;ZILOG COUNTER/TIMER 0
  42:     -	0081          	CTC1			EQU	81H		;ZILOG COUNTER/TIMER 1
  43:     -	0082          	CTC2			EQU	82H		;ZILOG COUNTER/TIMER 2
  44:     -	0083          	CTC3			EQU	83H		;ZILOG COUNTER/TIMER 3
  45:				;
  46:     -	0000          	CTC_D0_VECTOR:		EQU	00000000B	;Data is a Vector
  47:     -	0001          	CTC_D0_CONTROL:		EQU	00000001B	;Data is a Control Word
  48:     -	0002          	CTC_D1_SW_RST:		EQU	00000010B	;Perform a software reset
  49:     -	0004          	CTC_D2_TCNEXT:		EQU	00000100B	;Time Constant follows
  50:     -	0000          	CTC_D3_AUTOTRG:		EQU	00000000B	;Automatic trigger when Time Constant loaded
  51:     -	0008          	CTC_D3_CLKTRG:		EQU	00001000B	;CLK/TRIG pin pulse starts timer
  52:     -	0000          	CTC_D4_FALLEDGE:	EQU	00000000B	;CLK/TRIG edge selection - falling edge
  53:     -	0010          	CTC_D4_RISEEDGE:	EQU	00010000B	;CLK/TRIG edge selection - rising edge
  54:     -	0000          	CTC_D5_PRESC_16:	EQU	00000000B	;Timer prescaler value of 16
  55:     -	0020          	CTC_D5_PRESC256:	EQU	00100000B	;Timer prescaler value of 256
  56:     -	0000          	CTC_D6_MODE_TIM:	EQU	00000000B	;Selects Timer mode
  57:     -	0040          	CTC_D6_MODE_CNT:	EQU	01000000B	;Selects Counter mode
  58:     -	0000          	CTC_D7_INT_DIS:		EQU	00000000B	;Disables Interrupt
  59:     -	0080          	CTC_D7_INT_EN:		EQU	10000000B	;Enables Interrupt
  60:				;
  61:     -	0000          	NULL			EQU	00H
  62:     -	000D          	CR			EQU	0DH
  63:     -	000A          	LF			EQU	0AH
  64:				;
