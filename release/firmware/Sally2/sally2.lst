 883:				;
 884:     -	0000          	NTRKS	EQU	0		;NUMBER OF TRACKS
 885:     -	0001          	STEPRT	EQU	1		;STEP RATE
 886:     -	0002          	NSECS	EQU	2		;SECTORS PER TRACK (HI/LOW)
 887:     -	0004          	NSIDES	EQU	4		;NUMBER OF SIDES
 888:     -	0005          	MEDIA	EQU	5		;MEDIA SIZE AND FORMAT BITS
 889:     -	0006          	SECLEN	EQU	6		;SECTOR LENGTH (HI/LOW)
 890:     -	0008          	DSKBITS	EQU	8		;MISC NAUGHTY BITS
 891:     -	0009          	SPARE0	EQU	9
 892:     -	000A          	SPARE1	EQU	10
 893:     -	000B          	SPARE2	EQU	11
 894:				
 895:     -	000C          	CMDSTS	EQU	12		;COMMAND STATUS
 896:     -	000D          	HDWSTS	EQU	13		;HARDWARE STATUS
 897:				
 898:     -	000E          	FLAGS	EQU	14		;FLAGS BYTE FOR DISK OPERATION
 899:     -	000F          	SPARE3	EQU	15
 900:				;
 901:				;
