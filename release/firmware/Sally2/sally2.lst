2069:				;
2070:				;	... DATA STRUCTURE FOR DRIVE PARAMETER BLOCKS ...
2071:				;
2072:     -	0000          	NTRKS		EQU	0				;NUMBER OF TRACKS
2073:     -	0001          	STEPRT		EQU	1				;STEP RATE
2074:     -	0002          	NSECS		EQU	2				;SECTORS PER TRACK (HI/LOW)
2075:     -	0004          	NSIDES		EQU	4				;NUMBER OF SIDES
2076:     -	0005          	MEDIA		EQU	5				;MEDIA SIZE AND FORMAT BITS
2077:     -	0006          	SECLEN		EQU	6				;SECTOR LENGTH (HI/LOW)
2078:     -	0008          	DSKBITS		EQU	8				;MISC NAUGHTY BITS
2079:     -	0009          	SPARE0		EQU	9	
2080:     -	000A          	SPARE1		EQU	10	
2081:     -	000B          	SPARE2		EQU	11	
2082:				
2083:     -	000C          	CMDSTS		EQU	12				;COMMAND STATUS
2084:     -	000D          	HDWSTS		EQU	13				;HARDWARE STATUS
2085:     -	000E          	FLAGS		EQU	14				;FLAGS BYTE FOR DISK OPERATION
2086:     -	000F          	PERTRACK	equ 	15				;track for drive
2087:     -	0010          	MAXSEC		equ	16				;2-bytes max sectors	
2088:     -	0012          	PERSTEPRATE	equ	18				;steprate in FDC encoding
2089:     -	0013          	PERSECLEN	equ	19				;seclen in FDC encoding (0-3)
2090:     -	0014          	PERTRKS		equ	20				;if NTRKS = 1, number of tracks
2091:     -	0015          	PERSECS		equ	21				;if NTRKS = 1, number of secs
2092:     -	0016          	PERFLAGS	equ 	22				;if NTRKS = 1, number of heads	
2093:     -	0017          	PERSKEWTAB	equ	23				;NSECS+1 bytes for sector skew
2094:				;	
2095:				; Bits for FLAGS	
2096:				;	
2097:     -	0007          	FLAGMFMFM	equ	7				;0=MFM, 1=FM
2098:     -	0006          	FLAGHDDD	equ	6				;0=HD, 1=DD
2099:     -	0005          	FLAGSIDE	equ	5
2100:				;
2101:				;
2102:				;	EQUATES FOR BITS IN 'MEDIA' BYTE
2103:				;
2104:     -	0001          	SIZE		EQU	1				;DISK SIZE (1=EIGHT, 0=FIVE)
2105:     -	0002          	DENSTY		EQU	2				;DENSITY (1=MFM, 0=FM)
2106:				;
2107:				;
2108:				;	EQUATES FOR BITS IN 'DSKBITS' BYTE
2109:				;
2110:     -	0006          	PRESENT		EQU	6				;DRIVE PRESENT (1=PRESENT)
2111:				;
2112:				;	EQUATES FOR BITS IN 'PERFLAGS' BYTE
2113:				;
2114:     -	0001          	XFSIDE		EQU	1				;XF551 SKEW
2115:     -	0000          	PERCONF		EQU	0				;PERCOM (1=configured)
2116:				;
2117:				;
2118:				;	EQUATES FOR BITS IN 'CMDSTS' BYTE
2119:				;
2120:     -	0000          	BADCMD		EQU	0				;BAD COMMAND FRAME BIT
2121:     -	0001          	BADDAT		EQU	1				;BAD DATA FRAME BIT
2122:     -	0002          	BADRW		EQU	2				;BAD READ/WRITE OPERATION BIT
2123:     -	0003          	WRPROT		EQU	3				;WRITE PROTECTED BIT
2124:     -	0004          	ACTIVE		EQU	4				;DRIVE READY INDICATOR BIT
2125:     -	0005          	SEC256		EQU	5				;LONG/SHORT SECTOR BIT
