 149:23898+7	F6FF  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:23905+6	F700  23      		INC	HL
 151:23911+4	F701  7C      		LD	A,H
 152:23915+7	F702  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:23922+4	F704  3F      		CCF
