 104:23676+7	F6D7  3EFF    		LD	A,255
 105:23683+4	F6D9  B7      		OR	A
 106:23687+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
