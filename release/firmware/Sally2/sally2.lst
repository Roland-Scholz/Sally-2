  80:				;
  81:				;
  82:				;	... DATA FRAME RECEIVE SUBROUTINE ...
  83:				;
  84:     -	F6BB          	RECVBUFF:
  85:23647+4	F6BB  F3      		DI
  86:23651+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:23661+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:23678+4	F6C2  FB      		EI
  89:23682+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:23689+6	F6C5  2B      		DEC	HL
  92:23695+7	F6C6  7E      		LD	A,(HL)
  93:23702+4	F6C7  B9      		CP	C
  94:23706+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:23713+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:23723+4	F6CD  B7      		OR	A
  98:23727+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23742+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23746+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23756+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
 103:23763+17	F6D4  CD6AFC  		CALL	SENDCHAR	;SEND 'NAK' FOR BAD DATA FRAME
 104:23780+7	F6D7  3EFF    		LD	A,255
 105:23787+4	F6D9  B7      		OR	A
 106:23791+10	F6DA  C9      		RET			;RETURN WITH ACC SET NON=ZERO
 107:				;
 108:				;
 109:				;
 110:				;
 111:				;
 112:				;	... BITBANG INPUT SUBROUTINE ...
 113:				;
 114:				;	CALL WITH BLOCK START POINTER IN HL. RETURNS WITH
 115:				;	HL POINTING TO LAST BYTE+1 OF BLOCK RECEIVED.
 116:				;	THE CARRY BIT IS SET IF THE BUFFER FILLED UP BEFORE
 117:				;	THE BIT STREAM STOPPED.
 118:				;
 119:				;
 120:     -	F6DB          	RXBLOCK:
 121:23801+10	F6DB  11AA0A  		LD	DE,2730		;SET ABORT COUNTER FOR 32 MILLISECONDS
 122:     -	F6DE          	SalyRXBLOCK:
 123:23811+10	F6DE  010000  		LD	BC,0		;CLEAR B/C FOR CHECKSUM DERRIVATION
 124:23821+12	F6E1  1823    		JR	RXB35		;GO START LOOPING FOR START BIT
 125:				;
 126:23833+4	F6E3  79      	RXB1:	LD	A,C		;4
 127:23837+4	F6E4  80      		ADD	A,B		;4
 128:23841+7	F6E5  CE00    		ADC	A,0		;7 ACCUMULATE CHECKSUM ATARI STYLE
 129:23848+4	F6E7  4F      		LD	C,A		;4
 130:23852+19	F6E8  E3      		EX	(SP),HL		;19
 131:23871+19	F6E9  E3      		EX	(SP),HL		;19
 132:23890+19	F6EA  E3      		EX	(SP),HL		;19
 133:23909+19	F6EB  E3      		EX	(SP),HL		;19
 134:23928+7	F6EC  0608    		LD	B,8		;7
 135:				;
 136:				;	SERIAL->PARALLEL CONVERSION AT 52 MICROSECONDS PER BIT
 137:				;
 138:23935+7	F6EE  3E0B    	RXB2:	LD	A,11		;  7 CYCLES
 139:23942+7	F6F0  3E0B    		LD	A,11		;  7 CYCLES
 140:23949+4	F6F2  00      		NOP			;  4 CYCLES
 141:23953+4	F6F3  3D      	RXB3:	DEC	A		; 44 CYCLES  (11*4)
 142:23957+10	F6F4  C2F3F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:23967+11	F6F7  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:23978+4	F6F9  17      		RLA			;  4 CYCLES
 145:23982+8	F6FA  CB1A    		RR	D		;  8 CYCLES
 146:23990+8+5	F6FC  10F0    		DJNZ	RXB2		; 13 CYCLES  (8 ON FINAL BIT)
 147:				
 148:23998+4	F6FE  42      		LD	B, D		;SAVE COPY OF LAST DATA BYTE IN B
 149:24002+7	F6FF  72      		LD	(HL),D		;THEN STORE IN MEMORY BUFFER @HL
 150:24009+6	F700  23      		INC	HL
 151:24015+4	F701  7C      		LD	A,H
 152:24019+7	F702  FEC3    		CP	HIGH (IOBUFF+LEN)
 153:24026+4	F704  3F      		CCF
 154:24030+5+6	F705  D8      		RET	C		;RETURN WITH CARRY SET IF BUFFER FILLED
 155:				
 156:     -	F706          	RXB35:
 157:24035+7	F706  3E47    		LD	A, CTC_D6_MODE_CNT + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL	; Set up values for CTC0
 158:24042+11	F708  D380    		OUT	(CTC0),A	;PUT CTC0 IN COUNTER MODE
 159:24053+4	F70A  AF      		XOR	A		;TIME CONSTANT OF 0 WHICH MEANS 256
 160:24057+11	F70B  D380    		OUT	(CTC0),A	;COUNT DATA HIGH->LOW EDGES MOD 256
 161:24068+10	F70D  11A101  		LD	DE,417		;5 MILLISECONDS @ 12 MICROSECONDS/LOOP
 162:				
 163:24078+11	F710  DB80    	RXB4:	IN	A,(CTC0)
 164:24089+4	F712  B7      		OR	A
