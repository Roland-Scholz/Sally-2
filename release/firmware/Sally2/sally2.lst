 904:     -	0004          	NSIDES	EQU	4		;NUMBER OF SIDES
 905:     -	0005          	MEDIA	EQU	5		;MEDIA SIZE AND FORMAT BITS
 906:     -	0006          	SECLEN	EQU	6		;SECTOR LENGTH (HI/LOW)
 907:     -	0008          	DSKBITS	EQU	8		;MISC NAUGHTY BITS
