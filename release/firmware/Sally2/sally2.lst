 142:23853+10	F6F4  C2F3F6  		JP	NZ,RXB3		;110 CYCLES  (11*10)
 143:23863+11	F6F7  DB70    		IN	A,(ATARI)	; 11 CYCLES
 144:23874+4	F6F9  17      		RLA			;  4 CYCLES
 145:23878+8	F6FA  CB1A    		RR	D		;  8 CYCLES
