  93:23598+4	F6C7  B9      		CP	C
  94:23602+7+5	F6C8  2008    		JR	NZ,RBUFF2	;JUMP IF CHECKSUMS DON'T AGREE
  95:				
  96:23609+10	F6CA  1100C1  		LD	DE,IOBUFF
  97:23619+4	F6CD  B7      		OR	A
  98:23623+15	F6CE  ED52    		SBC	HL,DE		;ELSE COMPUTE LENGTH OF BLOCK LESS
  99:23638+4	F6D0  AF      		XOR	A		;CHECKSUM BYTE AND RETURN WITH
 100:23642+10	F6D1  C9      		RET			;RESULT IN HL AND ZERO FLAG SET
 101:				;
 102:23652+7	F6D2  3E4E    	RBUFF2:	LD	A,'N'
