2489:     -	0BEB  00      			DB	0					;TRACK#
2490:     -	0BEC  00      			DB	0					;SECTOR#
2491:     -	0BED  0000    			DW	0					;READ/WRITE POINTER
2492:     -	0BEF  0000    			DW	0					;AUXILLIARY PARAMETERS (2 BYTES)
2493:     -	0BF1  00      			DB	0					;OPERATION COMPLETION STATUS
