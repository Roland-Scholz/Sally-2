**** ..\src\main.mac ****
  47:				;
  48:				;	CODE PAST THIS POINT IS ONLY USED IN ATARI DISK MODE
  49:				;
  50:						INCLUDE	BITBANG.MAC
**** ..\src\BITBANG.MAC ****
   1:				;********************************************************
   2:				;*							*
   3:				;*	19200 BAUD SERIAL I/O FOR ATARI COMM PORT	*
   4:				;*							*
   5:				;********************************************************
   6:				;
   7:				;
   8:				;	19200 BAUD SERIAL I/O IS HALF DUPLEX DUE TO OBVIOUS
   9:				;	TIMING CONSTRAINTS. ALL TRANSFERS ARE DONE FROM 4K PAGE
  10:				;	ALIGNED BUFFER 'IOBUFF', WITH BLOCK START ADDRESS
  11:				;	ARRANGED SO END-OF-BLOCK CONDITION IS MET WHEN POINTER
  12:				;	ROLLS OVER THE NEXT EVEN PAGE BYTE BOUNDARY.
  13:				;
  14:				;	CALL WITH BLOCK START POINTER IN HL ,DATA POLARITY MASK
  15:				;	IN D (WHERE D=0 TRUE DATA, D=FF INVERTED DATA) AND
  16:				;	'C' OR 'E' HANDSHAKE CHARACTER IN E.
  17:				;
  18:				;
  19:     -	F66E          	SENDBUFF:
  20:23280+11	F66E  E5      		PUSH	HL		;SAVE DATA BLOCK POINTER
  21:23291+11	F66F  D5      		PUSH	DE		;SAVE POLARITY MASK FOR DATA
  22:23302+10	F670  2101C3  		LD	HL,IOBUFF+LEN+1
  23:23312+7	F673  73      		LD	(HL),E
  24:23319+7	F674  1600    		LD	D,0
  25:23326+17	F676  CD86F6  		CALL	XMITBUF		;SEND 'C' OR 'E' CHARACTER FROM E
  26:23343+10	F679  D1      		POP	DE
  27:23353+10	F67A  E1      		POP	HL
  28:23363+7	F67B  1E00    		LD	E,0
  29:23370+17	F67D  CD86F6  		CALL	XMITBUF		;THEN SEND DATA BLOCK TO ATARI
  30:23387+10	F680  2101C3  		LD	HL,IOBUFF+LEN+1
  31:23397+7	F683  73      		LD	(HL),E		;FALL THROUGH TO SEND CHECKSUM
  32:23404+7	F684  1600    		LD	D,0
  33:				;
  34:				;	CALL WITH DATA BLOCK POINTER IN HL.
  35:				;	PRESERVES MASK/CKECKSUM IN D/E.
  36:				;
  37:     -	F686          	XMITBUF:
  38:23411+4	F686  F3      		DI
  39:23415+10	F687  011BF7  		LD	BC,STARBIT
  40:     -	F68A          	SalyXMITBUF:
  41:23425+20	F68A  ED4312FF		LD	(CTCVEC+2),BC	;SET UP INITIAL INTERRUPT VECTOR
  42:23445+7	F68E  0608    		LD	B,8
  43:23452+7	F690  3E87    		LD	A, CTC_D7_INT_EN + CTC_D6_MODE_TIM + CTC_D2_TCNEXT + CTC_D1_SW_RST + CTC_D0_CONTROL
  44:23459+11	F692  D381    		OUT	(CTC1),A		;PROGRAM CTC1 TO INTERRUPT AT BIT RATE
  45:23470+7	F694  3E0D    		LD	A,13			;SET TIME CONSTANT TO 13 - 52us. EXACT IS 52.083us
  46:23477+11	F696  D381    		OUT	(CTC1),A		;COUNT 13*(16*250 NS) GIVES 19200 BAUD WITH 0.16% ERROR
  47:23488+4	F698  FB      		EI
  48:23492+12	F699  18FE    		JR	$		;SPIN HERE TILL INTERRUPTS GET US OUT
  49:				;
  50:				;
  51:				;
  52:				;
  53:				;
  54:				;
  55:				;	... INTERRUPT FOR COMMAND INPUT HIGH->LOW TRANSITION ..
  56:				;
  57:     -	F69B          	CSTART:
  58:23504+4	F69B  08      		EX	AF,AF'
  59:23508+4	F69C  D9      		EXX
  60:23512+7	F69D  3EFF    		LD	A,255
  61:23519+13	F69F  3255FF  		LD	(CMDFLG),A	;SET 'CMDFLG' FLAG TO ERROR STATE FIRST
  62:23532+11	F6A2  D357    		OUT	(CDMUX),A	;SWITCH MUX TO ENABLE SERIAL DATA IRQ
  63:23543+10	F6A4  21FBC2  		LD	HL,IOBUFF+LEN-5	;POINT DE 5 BYTES BEFORE END OF BUFFER
  64:23553+17	F6A7  CDDBF6  		CALL	RXBLOCK		;ATTEMPT TO RECEIVE COMMAND FRAME
  65:23570+7+5	F6AA  300A    		JR	NC,CSTRT1	;JUMP IF NO DATA HAPPENED
  66:					
  67:23577+6	F6AC  2B      		DEC	HL
  68:23583+7	F6AD  7E      		LD	A,(HL)
  69:23590+4	F6AE  B9      		CP	C		;COMPARE DERRIVED AND RECVD CHECKSUMS
  70:23594+7+5	F6AF  2005    		JR	NZ,CSTRT1	;JUMP IF CHECKSUM ERROR
  71:				
  72:23601+7	F6B1  3E01    		LD	A,1
  73:23608+13	F6B3  3255FF  		LD	(CMDFLG),A	;SET FLAG IF GOOD COMMAND FRAME
  74:23621+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:23625+4	F6B7  D9      		EXX
  76:23629+4	F6B8  FB      		EI
  77:				
  78:23633+14	F6B9  ED4D    		RETI
