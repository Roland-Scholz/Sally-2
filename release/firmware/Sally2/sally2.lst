 917:     -	0001          	BADDAT	EQU	1		;BAD DATA FRAME BIT
 918:     -	0002          	BADRW	EQU	2		;BAD READ/WRITE OPERATION BIT
 919:     -	0003          	WRPROT	EQU	3		;WRITE PROTECTED BIT
 920:     -	0004          	ACTIVE	EQU	4		;DRIVE READY INDICATOR BIT
