  74:24103+4	F6B6  08      	CSTRT1:	EX	AF,AF'
  75:24107+4	F6B7  D9      		EXX
  76:24111+4	F6B8  FB      		EI
  77:				
  78:24115+14	F6B9  ED4D    		RETI
