  62:     -	FFB8          	SKWPTR:		EQU	FRMPTR+2		;POINTER TO SKEW TABLE
  63:     -	FFBA          	NSECTS:		EQU	SKWPTR+2		;NUMBER OF SECTORS
  64:     -	FFBB          	TRKSIZ:		EQU	NSECTS+1		;TRACK LENGTH IN BYTES
