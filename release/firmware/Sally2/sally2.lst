  86:23913+10	F6BC  2100C1  		LD	HL,IOBUFF
  87:23923+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:23940+4	F6C2  FB      		EI
  89:23944+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
  91:23951+6	F6C5  2B      		DEC	HL
