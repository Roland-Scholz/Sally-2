  87:23557+17	F6BF  CDDBF6  		CALL	RXBLOCK		;BITBANG A BLOCK OF INPUT DATA
  88:23574+4	F6C2  FB      		EI
  89:23578+7+5	F6C3  380D    		JR	C,RBUFF2	;JUMP IF BUFFER OVERFLOWED
  90:				
