 194:25918+7	F71F  7E      		LD	A,(HL)		;LOAD A WITH TRANSMIT DATA BYTE
 195:25925+6	F720  23      		INC	HL		; AND INCREMENT BUFFER POINTER
 196:25931+4	F721  AA      		XOR	D		;DO DATA POLARITY THING
 197:25935+4	F722  4F      		LD	C,A		;THEN STUFF IN C FOR SHIFTING OUT
 198:25939+4	F723  83      		ADD	A,E
